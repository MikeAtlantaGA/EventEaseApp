@inject TooltipService TooltipService
@using RegistrationModel = EventEaseApp.Models.AttendeeRegistration

@if (Visible && !string.IsNullOrWhiteSpace(EventName))
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);" aria-modal="true" role="dialog" @onclick="HandleCloseAsync">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Attendees for @EventName</h5>
                    <button type="button" class="btn-close" @onclick="HandleCloseAsync" aria-label="Close" data-bs-toggle="tooltip" data-bs-title="Close attendee list"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <p class="mb-0">Manage registrations for this event.</p>
                        <button class="btn btn-primary" @onclick="HandleRegisterAsync" data-bs-toggle="tooltip" data-bs-title="Register a new attendee for this event">
                            <span class="bi bi-person-plus-fill"></span>
                            Register Attendee
                        </button>
                    </div>

                    @if (Attendees.Count == 0)
                    {
                        <p>No attendees are currently registered for this event.</p>
                    }
                    else
                    {
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Ticket</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var attendee in Attendees)
                                {
                                    <tr>
                                        <td>@attendee.FirstName @attendee.LastName</td>
                                        <td>@attendee.TicketType</td>
                                        <td>
                                            <button class="btn btn-secondary btn-sm me-1" @onclick="() => OnEdit.InvokeAsync(attendee)" data-bs-toggle="tooltip" data-bs-title="Edit this attendee registration"><span class="bi bi-pencil"></span></button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => OnDelete.InvokeAsync(attendee)" data-bs-toggle="tooltip" data-bs-title="Delete this attendee registration"><span class="bi bi-trash"></span></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public string EventName { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<RegistrationModel> Attendees { get; set; } = Array.Empty<RegistrationModel>();

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnRegister { get; set; }

    [Parameter]
    public EventCallback<RegistrationModel> OnEdit { get; set; }

    [Parameter]
    public EventCallback<RegistrationModel> OnDelete { get; set; }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        return TooltipService.InitializeAsync().AsTask();
    }

    private Task HandleCloseAsync() => OnClose.InvokeAsync();

    private Task HandleRegisterAsync() => OnRegister.InvokeAsync();
}