@implements IDisposable
@inject AttendeeRegistrationService RegistrationService
@inject UserSessionService SessionService
@inject TooltipService TooltipService
@using RegistrationModel = EventEaseApp.Models.AttendeeRegistration

@if (!isLoaded)
{
    <p>Loading registration form...</p>
}
else
{
    <EditForm EditContext="editContext" OnValidSubmit="HandleValidSubmitAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Event</label>
            <input class="form-control" value="@registration.EventName" disabled />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">First Name</label>
                <InputText class="form-control" @bind-Value="registration.FirstName" />
                <ValidationMessage For="@(() => registration.FirstName)" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Last Name</label>
                <InputText class="form-control" @bind-Value="registration.LastName" />
                <ValidationMessage For="@(() => registration.LastName)" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="registration.Email" />
                <ValidationMessage For="@(() => registration.Email)" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Phone</label>
                <InputText class="form-control" @bind-Value="registration.Phone" />
                <ValidationMessage For="@(() => registration.Phone)" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Ticket Type</label>
            <InputSelect class="form-select" @bind-Value="registration.TicketType">
                <option value="">Select a ticket type</option>
                <option value="General Admission">General Admission</option>
                <option value="VIP">VIP</option>
                <option value="Student">Student</option>
            </InputSelect>
            <ValidationMessage For="@(() => registration.TicketType)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Notes</label>
            <InputTextArea class="form-control" @bind-Value="registration.Notes" />
            <ValidationMessage For="@(() => registration.Notes)" />
        </div>

        <div class="form-check mb-3">
            <InputCheckbox class="form-check-input" @bind-Value="registration.AcceptTerms" />
            <label class="form-check-label">I confirm the registration details are accurate.</label>
            <ValidationMessage For="@(() => registration.AcceptTerms)" />
        </div>

        <button class="btn btn-primary me-2" type="submit" data-bs-toggle="tooltip" data-bs-title="@(IsEditing ? "Save registration changes" : "Save this attendee registration")">@(IsEditing ? "Save Changes" : "Register Attendee")</button>
        @if (IsEditing)
        {
            <button class="btn btn-danger me-2" type="button" @onclick="RequestDeleteAsync" data-bs-toggle="tooltip" data-bs-title="Delete this attendee registration">Delete Registration</button>
        }
        <button class="btn btn-outline-secondary" type="button" @onclick="CancelAsync" data-bs-toggle="tooltip" data-bs-title="Close this registration form">Cancel</button>
    </EditForm>
}

@code {
    [Parameter, EditorRequired]
    public int EventId { get; set; }

    [Parameter, EditorRequired]
    public string EventName { get; set; } = string.Empty;

    [Parameter]
    public RegistrationModel? InitialRegistration { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public EventCallback OnDeleteRequested { get; set; }

    private RegistrationModel registration = new();
    private EditContext editContext = default!;
    private bool isLoaded;
    private int currentEventId;
    private string? currentEventName;
    private Guid? currentRegistrationId;

    private bool IsEditing => registration.Id != Guid.Empty;

    protected override async Task OnParametersSetAsync()
    {
        await SessionService.InitializeAsync();
        await RegistrationService.InitializeAsync();

        var nextRegistrationId = InitialRegistration?.Id;
        if (currentEventId == EventId && currentEventName == EventName && currentRegistrationId == nextRegistrationId && isLoaded)
        {
            return;
        }

        currentEventId = EventId;
        currentEventName = EventName;
        currentRegistrationId = nextRegistrationId;
        var draft = SessionService.State.DraftRegistration;
        var matchesDraft = draft.EventId == EventId || (draft.EventId == 0 && string.Equals(draft.EventName, EventName, StringComparison.OrdinalIgnoreCase));

        registration = InitialRegistration != null
            ? CloneRegistration(InitialRegistration)
            : matchesDraft
                ? CloneRegistration(draft)
                : new RegistrationModel { EventId = EventId, EventName = EventName };

        registration.EventId = EventId;
        registration.EventName = EventName;

        if (editContext != null)
        {
            editContext.OnFieldChanged -= PersistDraftOnFieldChanged;
        }

        editContext = new EditContext(registration);
        editContext.OnFieldChanged += PersistDraftOnFieldChanged;
        isLoaded = true;
    }

    private async void PersistDraftOnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        registration.EventId = EventId;
        registration.EventName = EventName;
        await InvokeAsync(() => SessionService.SaveDraftRegistrationAsync(registration));
    }

    private async Task HandleValidSubmitAsync()
    {
        registration.EventId = EventId;
        registration.EventName = EventName;
        if (registration.Id == Guid.Empty)
        {
            await RegistrationService.AddAsync(CloneRegistration(registration));
        }
        else
        {
            await RegistrationService.UpdateAsync(CloneRegistration(registration));
        }

        await SessionService.ClearDraftRegistrationAsync();
        await OnSaved.InvokeAsync();
    }

    private async Task CancelAsync()
    {
        registration.EventId = EventId;
        registration.EventName = EventName;
        await SessionService.SaveDraftRegistrationAsync(registration);
        await OnCancel.InvokeAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        return TooltipService.InitializeAsync().AsTask();
    }

    private async Task RequestDeleteAsync()
    {
        if (!IsEditing)
        {
            return;
        }

        await OnDeleteRequested.InvokeAsync();
    }

    private static RegistrationModel CloneRegistration(RegistrationModel source)
    {
        return new RegistrationModel
        {
            Id = source.Id,
            EventId = source.EventId,
            EventName = source.EventName,
            FirstName = source.FirstName,
            LastName = source.LastName,
            Email = source.Email,
            Phone = source.Phone,
            TicketType = source.TicketType,
            Notes = source.Notes,
            AcceptTerms = source.AcceptTerms,
            RegisteredAtUtc = source.RegisteredAtUtc
        };
    }

    public void Dispose()
    {
        if (editContext != null)
        {
            editContext.OnFieldChanged -= PersistDraftOnFieldChanged;
        }
    }
}