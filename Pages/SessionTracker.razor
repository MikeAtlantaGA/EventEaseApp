@page "/session-tracker"
@implements IDisposable
@using EventEaseApp.Components
@inject EventService EventService
@inject UserSessionService SessionService
@inject AttendeeRegistrationService RegistrationService

<PageTitle>Session Tracker</PageTitle>

<h1>Session Tracker</h1>
<p class="text-muted">This page is provided for diagnostic and demonstration purposes only. It would not be exposed to end users in a production system.</p>

@if (!isLoaded)
{
    <p>Loading session state...</p>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h5">Session Details</h2>
            <p><strong>Session ID:</strong> @SessionService.State.SessionId</p>
            <p><strong>Started:</strong> @SessionService.State.SessionStartedUtc.ToLocalTime().ToString("MM/dd/yyyy HH:mm:ss")</p>
            <p><strong>Last Activity:</strong> @SessionService.State.LastActivityUtc.ToLocalTime().ToString("MM/dd/yyyy HH:mm:ss")</p>
            <p><strong>Last Visited Page:</strong> @SessionService.State.LastVisitedPage</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h5">Search State</h2>
                    <p><strong>Name:</strong> @DisplayValue(SessionService.State.SearchCriteria.Name)</p>
                    <p><strong>Date:</strong> @DisplayValue(SessionService.State.SearchCriteria.Date)</p>
                    <p><strong>Location:</strong> @DisplayValue(SessionService.State.SearchCriteria.Location)</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h5">Draft Registration</h2>
                    <p><strong>Event:</strong> @DisplayValue(SessionService.State.DraftRegistration.EventName)</p>
                    <p><strong>Name:</strong> @DisplayValue($"{SessionService.State.DraftRegistration.FirstName} {SessionService.State.DraftRegistration.LastName}".Trim())</p>
                    <p><strong>Email:</strong> @DisplayValue(SessionService.State.DraftRegistration.Email)</p>
                    <p><strong>Ticket Type:</strong> @DisplayValue(SessionService.State.DraftRegistration.TicketType)</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <button class="btn btn-outline-secondary me-2" @onclick="ClearDraftAsync">Clear Draft Registration</button>
        <button class="btn btn-danger" @onclick="ResetSessionAsync">Reset Session</button>
    </div>

    <div class="card border-danger-subtle">
        <div class="card-body">
            <h2 class="h5 text-danger">Data Tools</h2>
            <p class="mb-3">Use these actions to restore sample event data or clear stored registrations. Each action requires confirmation.</p>
            <button class="btn btn-outline-warning me-2 mb-2" @onclick='() => ShowResetConfirmation(ResetAction.ResetEvents)'>Reset Events</button>
            <button class="btn btn-outline-warning me-2 mb-2" @onclick='() => ShowResetConfirmation(ResetAction.ResetRegistrations)'>Reset Registrations</button>
            <button class="btn btn-danger mb-2" @onclick='() => ShowResetConfirmation(ResetAction.ResetAllData)'>Reset All Data</button>
        </div>
    </div>

    <ConfirmationModal Visible="showResetConfirmation"
                       Title="@GetConfirmationTitle()"
                       Message="@GetConfirmationMessage()"
                       OnCancel="CloseResetConfirmation"
                       OnConfirm="ConfirmResetAsync" />
}

@code {
    private bool isLoaded;
    private bool showResetConfirmation;
    private ResetAction pendingResetAction;

    protected override async Task OnInitializedAsync()
    {
        await EventService.InitializeAsync();
        await RegistrationService.InitializeAsync();
        await SessionService.InitializeAsync();
        await SessionService.SetLastVisitedPageAsync(AppRoutes.SessionTracker);
        SessionService.OnChange += HandleSessionChanged;
        isLoaded = true;
    }

    private async Task ClearDraftAsync()
    {
        await SessionService.ClearDraftRegistrationAsync();
    }

    private async Task ResetSessionAsync()
    {
        await SessionService.ResetSessionAsync();
        await SessionService.SetLastVisitedPageAsync(AppRoutes.SessionTracker);
    }

    private void ShowResetConfirmation(ResetAction action)
    {
        pendingResetAction = action;
        showResetConfirmation = true;
    }

    private void CloseResetConfirmation()
    {
        showResetConfirmation = false;
        pendingResetAction = ResetAction.None;
    }

    private async Task ConfirmResetAsync()
    {
        switch (pendingResetAction)
        {
            case ResetAction.ResetEvents:
                await EventService.ResetAsync();
                break;
            case ResetAction.ResetRegistrations:
                await RegistrationService.ResetAsync();
                break;
            case ResetAction.ResetAllData:
                await EventService.ResetAsync();
                await RegistrationService.ResetAsync();
                await SessionService.ResetSessionAsync();
                await SessionService.SetLastVisitedPageAsync(AppRoutes.SessionTracker);
                break;
            default:
                return;
        }

        CloseResetConfirmation();
    }

    private string GetConfirmationTitle()
    {
        return pendingResetAction switch
        {
            ResetAction.ResetEvents => "Reset Events",
            ResetAction.ResetRegistrations => "Reset Registrations",
            ResetAction.ResetAllData => "Reset All Data",
            _ => "Confirm Reset"
        };
    }

    private string GetConfirmationMessage()
    {
        return pendingResetAction switch
        {
            ResetAction.ResetEvents => "Restore the default sample events. Existing event changes will be lost.",
            ResetAction.ResetRegistrations => "Delete all attendee registrations stored in the browser.",
            ResetAction.ResetAllData => "Restore default events, delete all attendee registrations, and reset saved session state.",
            _ => "Are you sure you want to continue?"
        };
    }

    private void HandleSessionChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "(empty)" : value;
    }

    public void Dispose()
    {
        SessionService.OnChange -= HandleSessionChanged;
    }

    private enum ResetAction
    {
        None,
        ResetEvents,
        ResetRegistrations,
        ResetAllData
    }
}